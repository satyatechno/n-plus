{
  "name": "nplus",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "check": "yarn prettier:check && yarn typecheck && yarn linter",
    "android": "react-native run-android",
    "android:dev": "react-native run-android --mode=developmentdebug --appId=com.nmas.supernova.development",
    "android:test": "react-native run-android --mode=envTestingdebug --appId=com.nmas.supernova.testing",
    "android:stag": "react-native run-android --mode=stagingdebug --appId=com.nmas.supernova.staging",
    "android:prod": "react-native run-android --mode=productiondebug --appId=com.nmas.supernova",
    "android:dev-release": "react-native run-android --mode=developmentrelease --appId=com.nmas.supernova.development",
    "android:test-release": "react-native run-android --mode=envTestingrelease --appId=com.nmas.supernova.testing",
    "android:stag-release": "react-native run-android --mode=stagingrelease --appId=com.nmas.supernova.staging",
    "android:prod-release": "react-native run-android --mode=productionrelease --appId=com.nmas.supernova",
    "android:test-aab": "cd android && ./gradlew bundleEnvTestingRelease",
    "android:test-apk": "cd android && ./gradlew assembleEnvTestingRelease",
    "android:dev-apk": "cd android && ./gradlew assembleDevelopmentRelease",
    "android:stag-apk": "cd android && ./gradlew assembleStagingRelease",
    "android:stag-aab": "cd android && ./gradlew bundleStagingRelease",
    "android:prod-apk": "cd android && ./gradlew assembleProductionRelease",
    "android:prod-aab": "cd android && ./gradlew bundleProductionRelease",
    "ios": "react-native run-ios",
    "ios:dev": "react-native run-ios --scheme nplusDevelopment --simulator 'iPhone 16 Pro'",
    "ios:test": "react-native run-ios --scheme nplusTesting --simulator 'iPhone 16 Pro'",
    "ios:stag": "react-native run-ios --scheme nplusStaging --simulator 'iPhone 16 Pro'",
    "ios:prod": "react-native run-ios --scheme nplusProduction --simulator 'iPhone 16 Pro'",
    "lint": "eslint .",
    "start": "react-native start",
    "start:rozenite": "WITH_ROZENITE=true react-native start",
    "test": "jest",
    "linter": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "prettier": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "prettier:check": "prettier --check 'src/**/*.{js,jsx,ts,tsx}'",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@hookform/resolvers": "^5.0.1",
    "@invertase/react-native-apple-authentication": "^2.4.1",
    "@react-native-community/datetimepicker": "^8.4.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/analytics": "23.8.3",
    "@react-native-firebase/app": "23.8.3",
    "@react-native-firebase/auth": "23.8.3",
    "@react-native-firebase/crashlytics": "23.8.3",
    "@react-native-google-signin/google-signin": "^14.0.1",
    "@react-native-voice/voice": "git+https://github.com/react-native-voice/voice.git",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/native": "^7.1.10",
    "@react-navigation/native-stack": "^7.3.14",
    "@rn-org/react-native-geofencing": "^0.1.0",
    "@shopify/flash-list": "^1.8.3",
    "@shopify/react-native-skia": "^2.4.14",
    "events": "^3.3.0",
    "graphql": "^16.11.0",
    "i18next": "^25.2.1",
    "immer": "^10.1.1",
    "indigitall-react-native-plugin": "^2.16.2",
    "js-sha256": "^0.11.1",
    "lodash": "^4.17.21",
    "lottie-react-native": "^7.3.4",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "react": "19.0.0",
    "react-hook-form": "^7.56.2",
    "react-i18next": "^15.5.2",
    "react-native": "0.79.1",
    "react-native-appsflyer": "^6.17.7",
    "react-native-config": "^1.5.5",
    "react-native-device-info": "^14.0.4",
    "react-native-fast-image": "^8.6.3",
    "react-native-fbsdk-next": "^13.4.1",
    "react-native-google-cast": "^4.9.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-mmkv": "^3.2.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-performance": "^6.0.0",
    "react-native-permissions": "^5.4.4",
    "react-native-reanimated": "^3.18.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.4.1",
    "react-native-screens": "^4.10.0",
    "react-native-sha256": "^1.4.10",
    "react-native-svg": "^15.11.2",
    "react-native-uuid": "^2.0.3",
    "react-native-video": "^6.19.0",
    "react-native-webview": "^13.13.5",
    "yup": "^1.6.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.1",
    "@react-native/eslint-config": "0.79.1",
    "@react-native/metro-config": "0.79.1",
    "@react-native/typescript-config": "0.79.1",
    "@rozenite/metro": "^1.1.0",
    "@rozenite/mmkv-plugin": "^1.1.0",
    "@rozenite/network-activity-plugin": "^1.1.0",
    "@rozenite/performance-monitor-plugin": "^1.1.0",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "react-native-svg-transformer": "^1.5.0",
    "react-test-renderer": "19.0.0",
    "reactotron-react-native": "^5.1.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "yarn linter",
      "yarn prettier"
    ]
  }
}
