def node_require(script)
  # Resolve script with node to allow for hoisting
  resolved = Pod::Executable.execute_command(
    'node',
    [
      '-p',
      "require.resolve('#{script}', {paths: [process.argv[1]]})",
      __dir__
    ]
  ).strip

  require resolved
end

# Require helper scripts
node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

$RNJWPlayerUseGoogleCast = true
$RNJWPlayerUseGoogleIMA  = true

# react-native-video configuration
$RNVideoUseGoogleIMA = true

linkage = ENV['USE_FRAMEWORKS']
if linkage
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'nplus' do
  config = use_native_modules!

  # Choose only ONE use_frameworks! — keeping static as you wrote
  use_frameworks! :linkage => :static
  $RNFirebaseAsStaticFramework = true

  # Google Mobile Ads SDK
  pod 'Google-Mobile-Ads-SDK'

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Permissions must be INSIDE the target
  setup_permissions([
    'Microphone'
  ])

  target 'nplusDevelopment' do
    inherit! :complete
  end

  target 'nplusTesting' do
    inherit! :complete
  end

  target 'nplusStaging' do
    inherit! :complete
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )
  end
end
